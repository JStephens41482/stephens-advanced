{
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/robots.txt", "dest": "/robots.txt" },
    { "src": "/apply", "dest": "/apply.html" },
    { "src": "/services/(.*)", "dest": "/services/$1.html" },
    { "src": "/systems/(.*)", "dest": "/systems/$1.html" },
    { "src": "/areas/(.*)", "dest": "/areas/$1.html" },
    { "src": "/app(.*)", "dest": "/appv2.html" },
    { "src": "/portal(.*)", "dest": "/portal.html" },
    { "src": "/w9.pdf", "dest": "/w9.pdf" },
    { "src": "/coi.pdf", "dest": "/coi.pdf" },
    { "src": "^/$", "dest": "/indexv2.html" },
    { "src": "/(.*)", "dest": "/indexv2.html" }
  ]
}
